SOURCE=/Volumes/SJCAM/DCIM/Movie
DEST=$HOME/Movies/SJCamMovies/NewAutoProcess
COMBINED_DIR=$HOME/Movies/SJCamMovies/Combined
# Only after combine_dashcam.sh runs ffmpeg successfully: 1 = delete segments in DEST, 0 = keep them
DELETE_SEGMENTS_AFTER_COMBINE=0

# YouTube upload flow (scripts/upload_sdcard_youtube.sh)
YT_TITLE_PREFIX=Dashcam
YT_DESCRIPTION="Uploaded by dashcam-cli"
YT_CATEGORY_ID=2
YT_PRIVACY=unlisted
READY_TAG=READY
DONE_TAG=DONE
GOOGLE_CLIENT_SECRETS=$HOME/.config/youtube/client_secrets.json
GOOGLE_TOKEN_FILE=$HOME/.config/youtube/token.json
# Optional safety lock: only upload if authenticated channel ID matches this.
# YT_TARGET_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx
# Optional: add each upload to this playlist (ID from Studio URL …/playlist/PL…/…).
# YT_PLAYLIST_ID=PLo2Twz6t7kG794ARH8jD6z9VuqzHnfu9B
